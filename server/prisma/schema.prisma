generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite: use strings for enums / JSON (parse in app code)

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  passwordHash   String
  role           String
  studentId      String?  @unique
  course         String?
  department     String?
  profilePicture String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  studentConcerns  Concern[]      @relation("StudentConcerns")
  assignedConcerns Concern[]      @relation("AssignedConcerns")
  comments         Comment[]
  notifications    Notification[]
}

model Concern {
  id           String   @id @default(cuid())
  title        String
  description  String
  category     String
  subcategory  String
  status       String   @default("pending")
  priority     String   @default("medium")
  studentId    String
  student      User     @relation("StudentConcerns", fields: [studentId], references: [id])
  studentName  String
  assignedToId String?
  assignee     User?    @relation("AssignedConcerns", fields: [assignedToId], references: [id])
  department   String
  attachments  String?
  formData     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  comments     Comment[]
}

model Comment {
  id         String   @id @default(cuid())
  concernId  String
  concern    Concern  @relation(fields: [concernId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  authorName String
  authorRole String
  visibleTo  String
  content    String
  createdAt  DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  read      Boolean  @default(false)
  type      String
  concernId String?
  createdAt DateTime @default(now())
}
