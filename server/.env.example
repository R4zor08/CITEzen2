# SQLite database file (relative to prisma/schema.prisma)
DATABASE_URL="file:./dev.db"

# API port
PORT=3001

# Optional: allowed browser origins (comma-separated). Omit for dev default (reflect any origin).
# Include both local Vite and your ngrok URL when tunneling frontend + API, e.g.:
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,https://YOUR-SUBDOMAIN.ngrok-free.app

# Optional: override default admin password when seeding (default: Admin3msu)
# SEED_ADMIN_PASSWORD=

# Optional: max JSON body size (profile pictures are sent as base64)
# JSON_BODY_LIMIT=15mb
